    {
      "name": "CreateBooking - POST /booking",
      "item": [
        {
          "name": "Create Booking - returns 200 with bookingid and matching booking object",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const body = pm.response.json();",
                  "const payload = JSON.parse(pm.request.body.raw);",
                  "",
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('bookingid is a number', function () {",
                  "    pm.expect(typeof body.bookingid).to.equal('number');",
                  "});",
                  "",
                  "pm.test('booking object matches request payload', function () {",
                  "    pm.expect(body.booking.firstname).to.equal(payload.firstname);",
                  "    pm.expect(body.booking.lastname).to.equal(payload.lastname);",
                  "    pm.expect(body.booking.totalprice).to.equal(payload.totalprice);",
                  "    pm.expect(body.booking.depositpaid).to.equal(payload.depositpaid);",
                  "    pm.expect(body.booking.bookingdates.checkin).to.equal(payload.bookingdates.checkin);",
                  "    pm.expect(body.booking.bookingdates.checkout).to.equal(payload.bookingdates.checkout);",
                  "    pm.expect(body.booking.additionalneeds).to.equal(payload.additionalneeds);",
                  "});",
                  "",
                  "pm.collectionVariables.set('bookingId', body.bookingid);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstname\": \"John\",\n  \"lastname\": \"Doe\",\n  \"totalprice\": 150,\n  \"depositpaid\": true,\n  \"bookingdates\": {\n    \"checkin\": \"2025-01-15\",\n    \"checkout\": \"2025-01-20\"\n  },\n  \"additionalneeds\": \"Breakfast\"\n}"
            },
            "url": {
